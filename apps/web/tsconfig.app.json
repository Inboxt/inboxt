{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"noEmit": true,
		"moduleDetection": "force",
		"useDefineForClassFields": true,
		"noUncheckedSideEffectImports": true,
		"paths": {
			"~components/*": ["./src/components/*"],
			"~context/*": ["./src/context/*"],
			"~forms/*": ["./src/forms/*"],
			"~hooks/*": ["./src/hooks/*"],
			"~layouts/*": ["./src/layouts/*"],
			"~lib/*": ["./src/lib/*"],
			"~modals/*": ["./src/modals/*"],
			"~pages/*": ["./src/pages/*"],
			"~utils/*": ["./src/utils/*"],
			"~routes/*": ["./src/routes/*"],
			"@inboxt/common": ["../../libs/common/src"],
			"@inboxt/ui": ["../../libs/ui/src"],
			"@inboxt/graphql": ["../../libs/graphql/src"]
		},
		"tsBuildInfoFile": "../../node_modules/.tmp/web.tsbuildinfo"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
