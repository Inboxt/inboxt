{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"noEmit": true,
		"moduleDetection": "force",
		"useDefineForClassFields": true,
		"noUncheckedSideEffectImports": true,
		"paths": {
			"~components/*": ["./src/components/*"],
			"~context/*": ["./src/context/*"],
			"~forms/*": ["./src/forms/*"],
			"~hooks/*": ["./src/hooks/*"],
			"~layouts/*": ["./src/layouts/*"],
			"~lib/*": ["./src/lib/*"],
			"~modals/*": ["./src/modals/*"],
			"~pages/*": ["./src/pages/*"],
			"~utils/*": ["./src/utils/*"],
			"~routes/*": ["./src/routes/*"],
			"@inbox-reader/common": ["../../libs/common/src"]
		},
		"tsBuildInfoFile": "../../node_modules/.tmp/web.tsbuildinfo"
	},
	"include": ["src"]
}
