{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"outDir": "./dist",
		"sourceMap": true,
		"declaration": true,
		"incremental": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"strictNullChecks": true,
		"strictPropertyInitialization": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"@inboxt/common": ["libs/common/src/index.ts"],
			"@inboxt/prisma": ["./prisma/client"],
			"~common/*": ["./src/common/*"],
			"~config/*": ["./src/config/*"],
			"~managers/*": ["./src/managers/*"],
			"~modules/*": ["./src/modules/*"],
			"~services/*": ["./src/services/*"],
			"~mail-templates/*": ["./src/mail-templates/*"]
		}
	},
	"include": ["src", "prisma/client/**/*"],
	"exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
