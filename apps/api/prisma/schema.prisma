generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model pgmigrations {
  id     Int      @id @default(autoincrement())
  name   String   @db.VarChar(255)
  run_on DateTime @db.Timestamp(6)
}

model article {
  savedItemId String     @id @db.Uuid
  contentHtml String
  contentText String
  saved_item  saved_item @relation(fields: [savedItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model label {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  userId           String             @db.Uuid
  name             String
  color            String?
  user             user               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item_label saved_item_label[]

  @@unique([userId, name], map: "label_userId_name_unique_index")
}

model saved_item {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  userId           String             @db.Uuid
  title            String
  originalUrl      String?
  sourceDomain     String?
  description      String?
  leadImage        String?
  wordCount        Int?
  author           String?
  type             saved_item_type
  status           saved_item_status  @default(ACTIVE)
  article          article?
  user             user               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item_label saved_item_label[]

  @@index([userId], map: "saved_item_userId_index")
}

model saved_item_label {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  savedItemId String     @db.Uuid
  labelId     String     @db.Uuid
  label       label      @relation(fields: [labelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item  saved_item @relation(fields: [savedItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt           DateTime     @default(now()) @db.Timestamp(6)
  logins              Int          @default(0)
  lastLogin           DateTime?    @db.Timestamp(6)
  emailAddress        String       @unique
  pendingEmailAddress String?
  password            String?
  username            String?
  isEmailVerified     Boolean      @default(false)
  emailVerifyCode     String?
  emailVerifyExpiry   DateTime?    @db.Timestamp(6)
  resetPasswordCode   String?
  resetPasswordExpiry DateTime?    @db.Timestamp(6)
  plan                user_plan    @default(FREE)
  label               label[]
  saved_item          saved_item[]
}

enum saved_item_status {
  ACTIVE
  ARCHIVED
  DELETED
}

enum saved_item_type {
  NEWSLETTER
  ARTICLE
}

enum user_plan {
  DEMO
  FREE
}
