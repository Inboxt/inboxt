generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model pgmigrations {
  id     Int      @id @default(autoincrement())
  name   String   @db.VarChar(255)
  run_on DateTime @db.Timestamp(6)
}

model article {
  savedItemId String     @id @db.Uuid
  contentHtml String
  contentText String
  saved_item  saved_item @relation(fields: [savedItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model label {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  userId           String             @db.Uuid
  name             String
  color            String?
  user             user               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item_label saved_item_label[]

  @@unique([userId, name], map: "label_userId_name_unique_index")
}

model saved_item {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  userId           String             @db.Uuid
  title            String
  originalUrl      String?
  sourceDomain     String?
  description      String?
  leadImage        String?
  wordCount        Int?
  author           String?
  type             saved_item_type
  status           saved_item_status  @default(ACTIVE)
  deletedSince     DateTime?          @db.Timestamp(6)
  article          article?
  highlight        highlight[]
  newsletter       newsletter?
  user             user               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item_label saved_item_label[]

  @@index([userId], map: "saved_item_userId_index")
}

model saved_item_label {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  savedItemId String     @db.Uuid
  labelId     String     @db.Uuid
  label       label      @relation(fields: [labelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_item  saved_item @relation(fields: [savedItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt             DateTime                @default(now()) @db.Timestamp(6)
  logins                Int                     @default(0)
  lastLogin             DateTime?               @db.Timestamp(6)
  emailAddress          String                  @unique
  pendingEmailAddress   String?
  password              String?
  username              String?
  isEmailVerified       Boolean                 @default(false)
  emailVerifyCode       String?
  emailVerifyExpiry     DateTime?               @db.Timestamp(6)
  resetPasswordCode     String?
  resetPasswordExpiry   DateTime?               @db.Timestamp(6)
  plan                  user_plan               @default(FREE)
  highlight             highlight[]
  inbound_email_address inbound_email_address[]
  label                 label[]
  saved_item            saved_item[]
}

model newsletter {
  savedItemId             String                   @id @db.Uuid
  inboundEmailAddressId   String?                  @db.Uuid
  contentHtml             String
  contentText             String
  messageId               String
  subscriptionId          String?                  @db.Uuid
  inbound_email_address   inbound_email_address?   @relation(fields: [inboundEmailAddressId], references: [id], onUpdate: NoAction)
  saved_item              saved_item               @relation(fields: [savedItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  newsletter_subscription newsletter_subscription? @relation(fields: [subscriptionId], references: [id], onUpdate: NoAction)
}

model newsletter_subscription {
  id                     String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt              DateTime                       @default(now()) @db.Timestamp(6)
  status                 newsletter_subscription_status @default(ACTIVE)
  name                   String
  lastReceivedAt         DateTime?                      @db.Timestamp(6)
  unsubscribeUrl         String?
  unsubscribeAttemptedAt DateTime?                      @db.Timestamp(6)
  inboundEmailAddressId  String                         @db.Uuid
  newsletter             newsletter[]
  inbound_email_address  inbound_email_address          @relation(fields: [inboundEmailAddressId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model inbound_email_address {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String?                   @db.Uuid
  createdAt               DateTime                  @default(now()) @db.Timestamp(6)
  deletedAt               DateTime?                 @db.Timestamp(6)
  localPart               String                    @db.VarChar(64)
  fullAddress             String                    @unique
  user                    user?                     @relation(fields: [userId], references: [id], onUpdate: NoAction)
  newsletter              newsletter[]
  newsletter_subscription newsletter_subscription[]

  @@unique([userId, localPart], map: "inbound_email_address_user_local_part_unique")
}

model highlight {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  savedItemId       String?             @db.Uuid
  userId            String              @db.Uuid
  saved_item        saved_item?         @relation(fields: [savedItemId], references: [id], onUpdate: NoAction)
  user              user                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  highlight_segment highlight_segment[]
}

model highlight_segment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  highlightId String    @db.Uuid
  xpath       String
  beforeText  String
  startOffset Int
  endOffset   Int
  afterText   String
  text        String?
  highlight   highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([highlightId], map: "highlight_segment_highlightId_index")
}

enum saved_item_status {
  ACTIVE
  ARCHIVED
  DELETED
}

enum saved_item_type {
  NEWSLETTER
  ARTICLE
}

enum user_plan {
  DEMO
  FREE
}

enum newsletter_subscription_status {
  ACTIVE
  UNSUBSCRIBED
}
