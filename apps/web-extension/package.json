	},
	"devDependencies": {
		"@types/react": "19.2.6",
		"@types/react-dom": "19.1.7",
		"@wxt-dev/module-react": "^1.1.3",
		"@wxt-dev/auto-icons": "1.1.0",
		"wxt": "^0.20.6"
