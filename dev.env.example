### API ####
# The port the API will listen on
API_PORT=7000
# Secret for JWT signing
API_JWT_SECRET=supersecretjwtsecret
# Public URL of the API. Used for links in emails and by the web app if needed.
# If you are running locally without a reverse proxy, this should match API_PORT.
API_URL=http://localhost:7000

### DATABASE ####
# These are used by both the API and the docker-compose database service.
DATABASE_HOST=database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=inboxt
DATABASE_PORT=5432
# Prisma connection string
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public"

### WEB ####
# The port the web development server will listen on
WEB_PORT=3000

### VALKEY (Redis) ####
VALKEY_HOST=valkey
VALKEY_PORT=6379

### MAIL ####
# Mailpit is used for local development to catch emails
MAIL_HOST=mailpit
MAIL_PORT=1025
# Port for the Mailpit web interface
MAIL_WEB_PORT=8025

### INBOUND NEWSLETTERS ####
# Domain used for generating inbound email addresses
INBOUND_EMAIL_ADDRESS_DOMAIN=

### STORAGE (Optional) ####
# Configuration for S3-compatible storage (e.g., Scaleway, AWS)
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_REGION=
# STORAGE_S3_BUCKET=

# Local path for temporary exports
EXPORTS_LOCAL_PATH=exports

### ERROR REPORTING (Optional) ####
# Sentry or Bugsink DSNs
# API_ERRORS_DSN=
# WEB_ERRORS_DSN=

### OTHER SETTINGS ####
# SECURE_COOKIES=true
# REQUIRE_EMAIL_VERIFICATION=true
# DISABLE_SIGNUP=false
