# --- General ---
NODE_ENV=production
# The public-facing URL of your instance. Used for emails, exports, and integrations.
APP_URL=http://localhost:7000

# --- Security ---
API_JWT_SECRET=replace-with-a-random-string
API_JWT_EXPIRES_IN=30d
# If true, cookies will only be sent over HTTPS. Set to false if you are using HTTP only (e.g. over a private network like Netbird/Tailscale without SSL).
# Defaults to true in production.
SECURE_COOKIES=true
# If true, users must verify their email before using the app.
REQUIRE_EMAIL_VERIFICATION=false
# If true, new registrations are disabled.
DISABLE_SIGNUP=false

# --- Database ---
# If you use the provided docker-compose.yml, you only need to set DATABASE_PASSWORD.
# The other variables will default to 'inboxt' and DATABASE_URL will be constructed automatically.
# DATABASE_URL=postgresql://inboxt:password@postgres:5432/inboxt
# DATABASE_NAME=inboxt
# DATABASE_USER=inboxt
DATABASE_PASSWORD=replace-with-a-random-password

# --- Valkey (Redis) ---
VALKEY_HOST=valkey
# VALKEY_PORT=6379

# --- Exports ---
EXPORTS_LOCAL_PATH=exports

# --- Storage (Optional, for S3-compatible storage) ---
# If provided, exports will be uploaded to S3.
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# --- Mail (Optional) ---
# Required for password recovery, notifications, and email verification.
# If not configured, emails will be logged to the container output instead of sent.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=user@example.com
# MAIL_PASSWORD=password

# --- Inbound Email (Optional) ---
# Required for newsletter features. See documentation for generic webhook schema.
# INBOUND_EMAIL_ADDRESS_DOMAIN=yourdomain.com

# --- Error Reporting (Optional) ---
# Sentry-compatible error tracking.
# API_ERRORS_DSN=https://example@errors.example.com/1
# WEB_ERRORS_DSN=https://example@errors.example.com/2